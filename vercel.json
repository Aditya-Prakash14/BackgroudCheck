{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next@latest"
    },
    {
      "src": "backend/package.json",
      "use": "@vercel/node@latest"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/src/server.ts",
      "methods": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "PATCH",
        "OPTIONS"
      ]
    },
    {
      "src": "/(.*)",
      "dest": "/frontend"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "buildCommand": "npm install --legacy-peer-deps && cd backend && npm install && npm run build && cd ../frontend && npm install && npm run build",
  "installCommand": "npm install --legacy-peer-deps"
}
